# =============================================================================
# UniMind API server — environment variables
# Copy to .env and fill in real values. Do not commit .env (it is in .gitignore).
# Loaded from: api_server/.env (see config.py)
# =============================================================================

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
# Used for session signing; change in production.
SECRET_KEY=change_me_to_a_long_random_string

# -----------------------------------------------------------------------------
# Google Gemini AI
# -----------------------------------------------------------------------------
# Get keys: https://aistudio.google.com/apikey
# If the API says "API key expired" or API_KEY_INVALID, create a NEW key there and replace the values below.
# The website calls this server’s /ai/* routes (keys are not in the browser).
# Key load order: this file (.env) → local.properties → gemini_keys.properties → gradle.properties.
# Restart the server after edits. Quick check: GET http://127.0.0.1:5000/ai/test-gemini
GEMINI_API_KEY=
# Up to 6 keys, comma-separated, no spaces (server tries the next key on errors):
GEMINI_API_KEYS=
# GEMINI_AI_API_KEY=  (alias for GEMINI_API_KEY)
# GOOGLE_API_KEY=  (optional; merged into the same pool as GEMINI_*)

# -----------------------------------------------------------------------------
# MySQL (XAMPP default: user root, empty password, database unimind)
# -----------------------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=unimind

# -----------------------------------------------------------------------------
# SMTP / email (password reset OTP, etc.)
# Gmail: use an App Password (16 chars, no spaces), not your normal login.
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_APP_PASSWORD=
# Optional display name for From: header
# UNIMIND_SMTP_SENDER=UniMind <your_email@gmail.com>
